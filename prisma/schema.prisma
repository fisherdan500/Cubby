generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  owner
  parent
  caretaker
  read_only
}

enum InviteStatus {
  pending
  accepted
  revoked
  expired
}

enum ActivityType {
  feeding
  diaper
  sleep
  pumping
  medicine
  measurement
  milestone
  note
  bath
  play
  mood
  supplement
  vaccine
  milk_inventory
}

enum TimerState {
  none
  running
  paused
  stopped
}

enum FeedingKind {
  breast
  bottle
  formula
  solids
}

enum NursingSide {
  left
  right
  both
}

enum DiaperKind {
  wet
  dirty
  mixed
  dry
}

enum ReminderKind {
  feeding
  diaper
  medicine
  pumping
  sleep
  play
}

enum MilkInventoryAction {
  stored
  fed
  discarded
  thawed
  donated
  expired
}

enum WebhookEvent {
  activity_created
  activity_updated
  activity_deleted
  timer_started
  timer_stopped
  reminder_due
}

enum DeliveryStatus {
  pending
  delivered
  failed
}

model User {
  id            String            @id @default(cuid())
  name          String
  email         String            @unique
  emailVerified Boolean           @default(false)
  image         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  sessions      Session[]
  accounts      Account[]
  memberships   HouseholdMember[]
  trustedDevices TrustedDevice[]
  sentInvites   Invite[]          @relation("InviteSender")
  acceptedInvites Invite[]        @relation("InviteAccepter")
  auditEvents   AuditEvent[]
  pushSubscriptions PushSubscription[]
  notificationPreferences NotificationPreference[]
  notificationLogs NotificationLog[]
  backupRecords BackupRecord[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([identifier])
}

model Household {
  id              String            @id @default(cuid())
  name            String
  createdByUserId String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  members         HouseholdMember[]
  invites         Invite[]
  babies          Baby[]
  contacts        Contact[]
  reminders       Reminder[]
  activities      ActivityLog[]
  trustedDevices  TrustedDevice[]
  auditEvents     AuditEvent[]
  settings        HouseholdSettings?
  apiKeys         ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  webhookDeliveries WebhookDelivery[]
  pushSubscriptions PushSubscription[]
  notificationPreferences NotificationPreference[]
  notificationLogs NotificationLog[]
  backupRecords   BackupRecord[]

  @@index([deletedAt])
  @@index([createdAt])
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole
  displayName String?
  joinedAt    DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities  ActivityLog[]
  auditEvents AuditEvent[]

  @@unique([householdId, userId])
  @@index([householdId, role])
  @@index([userId])
  @@index([deletedAt])
}

model Invite {
  id               String        @id @default(cuid())
  householdId      String
  email            String
  role             HouseholdRole
  tokenHash        String        @unique
  status           InviteStatus  @default(pending)
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  household        Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedBy        User          @relation("InviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy       User?         @relation("InviteAccepter", fields: [acceptedByUserId], references: [id])

  @@index([householdId, status])
  @@index([email])
  @@index([expiresAt])
}

model Baby {
  id          String        @id @default(cuid())
  householdId String
  name        String
  birthDate   DateTime?
  timezone    String        @default("UTC")
  notes       String?
  feedingWarningMinutes Int?
  diaperWarningMinutes  Int?
  sleepWarningMinutes   Int?
  preferredUnits Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  activities  ActivityLog[]
  reminders   Reminder[]
  notificationPreferences NotificationPreference[]

  @@index([householdId])
  @@index([deletedAt])
  @@index([createdAt])
}

model ActivityLog {
  id                String          @id @default(cuid())
  householdId       String
  babyId            String
  actorMemberId     String
  type              ActivityType
  occurredAt        DateTime
  startedAt         DateTime?
  endedAt           DateTime?
  durationSeconds   Int?
  timezone          String
  notes             String?
  source            String          @default("manual")
  timerState        TimerState      @default(none)
  pausedAt          DateTime?
  pausedSeconds     Int             @default(0)
  clientMutationId  String?
  deletedAt         DateTime?
  deletedByMemberId String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  household         Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  baby              Baby            @relation(fields: [babyId], references: [id], onDelete: Cascade)
  actorMember       HouseholdMember @relation(fields: [actorMemberId], references: [id], onDelete: Restrict)
  feeding           FeedingLog?
  diaper            DiaperLog?
  sleep             SleepLog?
  pumping           PumpingLog?
  medicine          MedicineLog?
  measurement       MeasurementLog?
  milestone         MilestoneLog?
  note              NoteLog?
  bath              BathLog?
  play              PlayLog?
  mood              MoodLog?
  supplement        SupplementLog?
  vaccine           VaccineLog?
  milkInventory     MilkInventoryLog?
  webhookDeliveries WebhookDelivery[]
  notificationLogs  NotificationLog[]

  @@index([householdId])
  @@index([babyId])
  @@index([type])
  @@index([occurredAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([householdId, babyId, type, occurredAt])
}

model FeedingLog {
  id         String       @id @default(cuid())
  activityId String      @unique
  mode       FeedingKind
  amount     Decimal?    @db.Decimal(10, 2)
  unit       String?
  side       NursingSide?
  bottleType String?
  food       String?
  leftSeconds Int?
  rightSeconds Int?
  activity   ActivityLog @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model DiaperLog {
  id          String       @id @default(cuid())
  activityId  String       @unique
  kind        DiaperKind
  color       String?
  consistency String?
  rashConcern Boolean      @default(false)
  condition   String?
  blowout     Boolean      @default(false)
  creamApplied Boolean     @default(false)
  activity    ActivityLog  @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model SleepLog {
  id         String       @id @default(cuid())
  activityId String      @unique
  sleepType  String?
  location   String?
  quality    String?
  activity   ActivityLog @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model PumpingLog {
  id          String       @id @default(cuid())
  activityId  String       @unique
  amount      Decimal?     @db.Decimal(10, 2)
  leftAmount  Decimal?     @db.Decimal(10, 2)
  rightAmount Decimal?     @db.Decimal(10, 2)
  unit        String?
  inventoryAction MilkInventoryAction?
  activity    ActivityLog  @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model MedicineLog {
  id          String       @id @default(cuid())
  activityId  String       @unique
  contactId   String?
  name        String
  dose        Decimal?     @db.Decimal(10, 2)
  unit        String?
  activity    ActivityLog  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  contact     Contact?     @relation(fields: [contactId], references: [id])

  @@index([contactId])
}

model SupplementLog {
  id          String       @id @default(cuid())
  activityId  String       @unique
  name        String
  dose        Decimal?     @db.Decimal(10, 2)
  unit        String?
  activity    ActivityLog  @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model MeasurementLog {
  id                String       @id @default(cuid())
  activityId        String       @unique
  weight            Decimal?     @db.Decimal(10, 2)
  weightUnit        String?
  length            Decimal?     @db.Decimal(10, 2)
  lengthUnit        String?
  headCircumference Decimal?     @db.Decimal(10, 2)
  headUnit          String?
  temperature       Decimal?     @db.Decimal(10, 2)
  temperatureUnit   String?
  measurementType   String?
  activity          ActivityLog  @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model MilestoneLog {
  id         String       @id @default(cuid())
  activityId String      @unique
  title      String
  category   String?
  activity   ActivityLog @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model NoteLog {
  id         String       @id @default(cuid())
  activityId String      @unique
  category   String?
  text       String
  activity   ActivityLog @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model BathLog {
  id         String       @id @default(cuid())
  activityId String      @unique
  bathType   String?
  products   String?
  waterTemp  String?
  activity   ActivityLog @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model PlayLog {
  id         String       @id @default(cuid())
  activityId String      @unique
  activityName String?
  location   String?
  intensity  String?
  activity   ActivityLog @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model MoodLog {
  id         String       @id @default(cuid())
  activityId String      @unique
  mood       String
  intensity  Int?
  context    String?
  activity   ActivityLog @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model VaccineLog {
  id         String       @id @default(cuid())
  activityId String      @unique
  name       String
  dose       String?
  lot        String?
  provider   String?
  dueDate    DateTime?
  documentUrl String?
  activity   ActivityLog @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model MilkInventoryLog {
  id         String       @id @default(cuid())
  activityId String      @unique
  action     MilkInventoryAction
  amount     Decimal?    @db.Decimal(10, 2)
  unit       String?
  storage    String?
  label      String?
  activity   ActivityLog @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model HouseholdSettings {
  id                       String    @id @default(cuid())
  householdId              String    @unique
  allowPublicRegistration  Boolean   @default(false)
  allowNewHouseholdCreation Boolean  @default(false)
  activityOrder            Json?
  activityVisibility       Json?
  unitPreferences          Json?
  dateFormat               String    @default("MMM d, yyyy")
  timeFormat               String    @default("h:mm a")
  sleepLocations           String[]  @default(["Crib", "Bassinet", "Contact nap", "Stroller", "Car seat"])
  medicines                String[]  @default([])
  supplements              String[]  @default([])
  nurseryModeEnabled       Boolean   @default(true)
  pwaInstallPromptEnabled  Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  household                Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String    @id @default(cuid())
  householdId String
  name        String
  keyHash     String    @unique
  prefix      String
  scopes      String[]
  babyId      String?
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([prefix])
}

model WebhookEndpoint {
  id          String    @id @default(cuid())
  householdId String
  name        String
  url         String
  secret      String
  events      WebhookEvent[]
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([householdId])
  @@index([deletedAt])
}

model WebhookDelivery {
  id          String         @id @default(cuid())
  householdId String
  endpointId  String
  event       WebhookEvent
  activityId  String?
  status      DeliveryStatus @default(pending)
  attemptCount Int           @default(0)
  nextAttemptAt DateTime?
  lastStatusCode Int?
  lastError   String?
  payload     Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  household   Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  endpoint    WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  activity    ActivityLog?   @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@index([householdId])
  @@index([endpointId])
  @@index([status])
}

model PushSubscription {
  id          String    @id @default(cuid())
  householdId String
  userId      String
  endpoint    String    @unique
  p256dh      String
  auth        String
  userAgent   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences NotificationPreference[]

  @@index([householdId])
  @@index([userId])
  @@index([deletedAt])
}

model NotificationPreference {
  id          String    @id @default(cuid())
  householdId String
  subscriptionId String?
  babyId      String?
  userId      String
  timerOverdue Boolean @default(true)
  activityCreated Boolean @default(false)
  reminders   Boolean @default(true)
  quietHoursStart String?
  quietHoursEnd String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  subscription PushSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  baby        Baby? @relation(fields: [babyId], references: [id], onDelete: Cascade)
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([userId])
  @@index([babyId])
}

model NotificationLog {
  id          String    @id @default(cuid())
  householdId String
  activityId  String?
  userId      String?
  kind        String
  status      DeliveryStatus @default(pending)
  title       String
  body        String?
  error       String?
  createdAt   DateTime @default(now())
  sentAt      DateTime?
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  activity    ActivityLog? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([householdId])
  @@index([activityId])
  @@index([status])
}

model BackupRecord {
  id          String    @id @default(cuid())
  householdId String
  actorUserId String?
  kind        String
  status      String
  itemCount   Int?
  checksum    String?
  error       String?
  createdAt   DateTime @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  actorUser   User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([householdId])
  @@index([createdAt])
}

model Contact {
  id          String        @id @default(cuid())
  householdId String
  name        String
  kind        String?
  phone       String?
  email       String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  medicines   MedicineLog[]

  @@index([householdId])
  @@index([deletedAt])
}

model Reminder {
  id             String       @id @default(cuid())
  householdId    String
  babyId         String
  kind           ReminderKind
  title          String
  cadenceMinutes Int?
  dueAt          DateTime?
  enabled        Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  household      Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  baby           Baby         @relation(fields: [babyId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([babyId])
  @@index([kind])
  @@index([dueAt])
  @@index([deletedAt])
}

model TrustedDevice {
  id          String    @id @default(cuid())
  householdId String?
  userId      String
  label       String
  pinHash     String?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([householdId])
  @@index([deletedAt])
}

model AuditEvent {
  id            String           @id @default(cuid())
  householdId   String
  actorUserId   String?
  actorMemberId String?
  action        String
  entityType    String
  entityId      String
  before        Json?
  after         Json?
  createdAt     DateTime         @default(now())
  household     Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  actorUser     User?            @relation(fields: [actorUserId], references: [id])
  actorMember   HouseholdMember? @relation(fields: [actorMemberId], references: [id])

  @@index([householdId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
